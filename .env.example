# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_book_assistant

# ChromaDB
CHROMA_PERSIST_DIR=../chroma_db

# Alibaba DashScope API
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-122b-a10b
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Local storage
UPLOAD_DIR=../uploads
SUMMARY_DIR=../summaries
MAX_UPLOAD_MB=50

